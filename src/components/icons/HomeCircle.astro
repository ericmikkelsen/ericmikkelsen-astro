---
const {
    class: className,
    current = false,
    dotTransitionName,
    ...rest
} = Astro.props;
---

<svg
    class:list={["ur-here", className]}
    xmlns="http://www.w3.org/2000/svg"
    width="192"
    height="192"
    viewBox="0 0 192 192"
    {...rest}
>
    <circle
        class="ur-here__shape ur-here__shape--circle"
        cx="96"
        cy="96"
        r="88"
        fill="transparent"
        stroke="currentColor"
        stroke-linejoin="round"
        stroke-width="16"
    />
    {!current && (
        <circle
            class="ur-here__dot"
            fill="currentColor"
            cx="96"
            cy="96"
            r="16"
            style={dotTransitionName ? `view-transition-name: ${dotTransitionName};` : undefined}
        />
    )}
</svg>

---
const {
    class: className,
    current = false,
    dotTransitionName,
    ...rest
} = Astro.props;
---

<svg
    class:list={["ur-here", className]}
    xmlns="http://www.w3.org/2000/svg"
    width="189.2"
    height="192"
    viewBox="0 0 189.2 192"
    {...rest}
>
    <path
        class="ur-here__shape ur-here__shape--nonagon"
        fill="transparent"
        stroke="currentColor"
        stroke-linejoin="round"
        stroke-width="16"
        d="m181 96-21 57-53 31-60-11-39-46V65l39-46 60-11 53 31Z"
    />
    {!current && (
        <circle
            class="ur-here__dot"
            fill="currentColor"
            cx="105.5"
            cy="146"
            r="16"
            style={dotTransitionName ? `view-transition-name: ${dotTransitionName};` : undefined}
        />
    )}
</svg>

---
const {
    class: className,
    current = false,
    dotTransitionName,
    ...rest
} = Astro.props;
---

<svg
    class:list={["ur-here", className]}
    xmlns="http://www.w3.org/2000/svg"
    width="192"
    height="168.5"
    viewBox="0 0 192 169"
    {...rest}
>
    <path
        class="ur-here__shape ur-here__shape--triangle"
        fill="transparent"
        stroke="currentColor"
        stroke-linejoin="round"
        stroke-width="15.8"
        d="M184 160H8l44-76L96 8l44 76Z"
    />
    {!current && (
        <circle
            class="ur-here__dot"
            fill="currentColor"
            cx="128"
            cy="128"
            r="16"
            style={dotTransitionName ? `view-transition-name: ${dotTransitionName};` : undefined}
        />
    )}
</svg>

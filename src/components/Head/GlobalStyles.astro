---
const { loadFont = true } = Astro.props;
---
    {loadFont &&
        <link
            rel="preload"
            href="/fonts/SpaceCowgirl/variable/SpaceCowgirl.woff2"
            as="font"
            type="font/woff2"
            crossorigin
        />
        <style>
            @font-face {
                font-family: SpaceCowgirl;
                src: url(/fonts/SpaceCowgirl/variable/SpaceCowgirl.woff2)
                    format("woff2-variations");
                font-display: swap;
            }
        </style>
    }
    <style>
        @view-transition {
            navigation: auto;
        }
    </style>

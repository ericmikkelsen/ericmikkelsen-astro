---
import Icons from "./Icons.astro";
import NewDot from "./NewDot.astro";
import {
    getCurrentPage,
    getSectionAccentColor,
    getSectionColor,
    getViewTransitionName,
    NAV_LINKS,
    type PageSlug,
} from "../modules/navigation";

const {
    class: _class,
    currentPage = getCurrentPage(Astro.url.pathname),
} = Astro.props as { class?: string | string[]; currentPage?: PageSlug };

const links = NAV_LINKS;
const iconClasses: Record<string, string> = {
    blog: "icon--square",
    projects: "icon--nonagon",
    resume: "icon--triangle",
    toys: "icon--circle",
};
---
<nav class:list={['nav', _class]}>
    {
        links.map(({ url, text, slug }) => {
            const iconClass = iconClasses[slug];
            const isCurrent = slug === currentPage;
            return (
                <a
                    href={url}
                    class:list={[
                        "nav__link", 
                        `nav__link--${slug}`,
                    ]}
                    style={`--section-bg: ${getSectionColor(slug)}; --section-accent: ${getSectionAccentColor(slug)}`}
                    aria-current={isCurrent ? "page" : undefined}
                >
                    <span class="nav__link-inner">

                        <span>{text}</span>
                        <span class="icon__wrapper" aria-hidden="true">
                            <Icons
                                icon={slug}
                                class={`icon ${iconClass}`}
                                current={isCurrent}
                                dotTransitionName={getViewTransitionName(slug)}
                                
                            />
                            {!isCurrent && 
                                <NewDot slug={slug}/>
                            }
                        </span>
                    </span>
                </a>
            );
        })
    }
</nav>
<style lang="scss">
    nav {
        --gap: 8px;
        background-color: #000;
        padding: var(--gap);
        grid-template-columns: repeat(auto-fit, minmax(min(6em, 100%), 1fr));
        grid-auto-rows: 1fr;
        gap: var(--gap);
        width: 100%;
        display: grid;
    }
    a {
        font-weight: 900;
        font-size: 1.25em;
        font-family: 'Courier New', Courier, monospace;
        display: flex;
        color: #000;
        transition: .2s background-color, .2s filter;
        outline: 4px solid transparent;
        outline-offset: 4px;
        filter: brightness(1);
        flex-grow: 1;
        flex-basis: 60px;
    }
    a:focus-visible {
        outline: 2px dashed;
        outline-offset: -6px;
    }
    .nav__link-inner {
        align-content: center;
        padding: 8px;
        display: flex;
        gap: 8px;
        flex-direction: column;
        text-align: center;
        justify-content: center;
        width: 100%;
    }
    a {
        background-color: var(--section-bg, #fffbbe);
    }
    .icon__wrapper {
        position: relative;
    }
</style>
<style is:global lang="scss">
    a circle {
        display: none;
    }
    a svg {
        width: auto;
        height: max(5vw, 3em);
    }
    a path,
    a circle {
        stroke-width: 1px;
        transition: .2s stroke-width;
        fill: rgba(255,255,255, 0);
        vector-effect: non-scaling-stroke;
    }
    .ur-here__dot {
        fill: currentColor;
    }
    a:hover path,
    a:hover circle {
        stroke-width: 8px;
        fill: rgba(255,255,255, 255);
    }
    a:hover .ur-here__dot {
        fill: currentColor;
    }
    a:active path,
    a:active circle {
        stroke-width: 1px;
    }
    .ur-here__dot {
        transition: .2s r;
    }
    a:active .ur-here__dot {
        r: 8px;
    }
    a .new-dot {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%,-50%);
    }
    a:not(:hover,:focus) .new-dot {
        view-transition-name: none;
    }
</style>

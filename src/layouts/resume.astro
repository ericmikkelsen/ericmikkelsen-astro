---
import Layout from '../layouts/index.astro';
import Markdown from '../components/Markdown.astro';

type WorkHistoryItem = {
    description?: string;
    organization: string;
    jobTitle: string;
    date: string;
    bulletPoints?: string[];
};

type LinkItem = {
    url: string;
    text: string;
};

const {frontmatter} = Astro.props;
const {title,description, ofText, image, workHistory = [], links = []} = frontmatter;
const typedWorkHistory = workHistory as WorkHistoryItem[];
const typedLinks = links as LinkItem[];
---
<Layout
    description={description}
    ofText={ofText}
    title={title}
    image={image}
>
    <Markdown class="markdown--main">
        <p>Links</p>
        {typedLinks.length > 0 && <ul>
            {typedLinks.map(({url,text}) => <li><a href={url}>{text}</a></li>)}
        </ul>}
        <slot />
        {typedWorkHistory.length > 0 &&
            <>
                <h2 id="work-history">Work history</h2>
            
                {typedWorkHistory.map(({date, jobTitle, organization, description, bulletPoints = []}) => (
                    <>
                        <h3>{organization}</h3>
                        <p>
                            <i>{jobTitle}</i>
                            <br /><time datetime="">{date}</time>
                            {description && <span><br />{description}</span>}
                        </p>
                        {bulletPoints.length > 0 && <ul>
                                {bulletPoints.map(point => <li>{point}</li>)}
                        </ul>}
                    </>
                ))}
            </>
        }
    </Markdown>
</Layout>
<style is:global>
    .markdown--main {
        padding-left: 8px;
        padding-right: 8px;
    }
</style>
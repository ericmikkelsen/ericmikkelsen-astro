---
import BaseHead from "../components/Head/BaseHead.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";

const {
    title = SITE_TITLE,
    description,
    lang = "en",
    h1 = true,
    showNav = false,
} = Astro.props;
---
<!doctype html>
<html lang={lang}>
    <head>
        <BaseHead title={title} description={description} />
    </head>
    <body>
        <slot />
    </body>
</html>

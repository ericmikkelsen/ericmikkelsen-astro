---
import BaseHead from "../components/BaseHead.astro";
import Nav from "../components/Nav.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";

const { 
	title, 
	description, 
	h1 = true,
} = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead 
			title={title} 
			description={description}
		/>
	</head>
	<body>
		<Nav class:list={["NAV"]} />
		<main>
				{h1 && !!title && 
					<h1>{title}</h1>
				}
				<slot />
		</main>
	</body>
</html>

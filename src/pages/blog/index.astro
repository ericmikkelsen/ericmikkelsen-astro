---
import { getCollection } from 'astro:content'
import Layout from '../../layouts/archive.astro'
let posts = (await getCollection('blog')).sort(
	(a, b) => {
		return a.data.date.valueOf() - b.data.date.valueOf()
	}
).map(post => {
	return {
		url: `/blog/${post.id}/`,
		text: post.data.title
	}
});
---
<Layout 
	description="Wholesome thoughts on web dev probably."
	links={posts.reverse()}
	reversed={true}
	title={'Blog'} 
	ofText={'of Eric Mikkelsen'}
/>
